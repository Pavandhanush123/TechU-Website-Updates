{
  "name": "techu-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "node --watch --env-file=.env src/index.js",
    "start": "NODE_ENV=production node src/index.js",
    "migrate:deploy": "node --env-file=.env ./scripts/prisma-with-env.mjs migrate deploy",
    "migrate:dev": "node --env-file=.env ./scripts/prisma-with-env.mjs migrate dev",
    "db:generate": "node --env-file=.env ./scripts/prisma-with-env.mjs generate",
    "db:pull": "node --env-file=.env ./scripts/prisma-with-env.mjs db pull"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "iron-session": "^8.0.4",
    "multer": "^2.1.1",
    "mysql2": "^3.22.3",
    "zod": "^3.24.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "prisma": "^6.19.3"
  },
  "prisma": {
    "seed": "node --env-file=.env prisma/seed.js"
  }
}
