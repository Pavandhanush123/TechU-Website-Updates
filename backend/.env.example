# Backend-only environment. Never expose these to the frontend.

NODE_ENV=production

# Required: 32+ char secret used to encrypt session cookies.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=

# ───────────────────────────────────────────────────────────────────────
# MySQL credentials. On Plesk: Databases → Add database, then copy the
# values it shows you into here (or into Plesk's Custom env variables).
# ───────────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASSWORD=

# Prisma (migrate + @prisma/client) — same database as DB_* above.
# Example: mysql://USER:PASSWORD@localhost:3306/DB_NAME
DATABASE_URL=

# Bootstrap admin (created on first /api/auth/ensure-admin call).
ADMIN_EMAIL=admin@techu.in
ADMIN_PASSWORD=TechU@Admin2026

# HTTP listen options.
PORT=3001
HOST=0.0.0.0

# Comma-separated list of allowed cross-origin frontend origins.
# In production behind one nginx (Plesk), the frontend and API share an origin
# and CORS isn't strictly required; leave the dev origins for local development.
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# Optional: rotate the admin password from env on next ensure-admin call.
# RESET_ADMIN_PASSWORD=true
