# Frontend (Vite) — only frontend-safe values. Anything in here ships to
# the browser at build time. NEVER put database URLs, JWT secrets,
# service keys, or backend-only config here.

# Base URL the frontend uses to call the backend API.
# Leave empty in production to use a same-origin /api path (when both apps
# are served from the same domain via nginx — typical Plesk setup).
# Set to e.g. "http://localhost:3001" or "https://api.example.com" if the
# backend is on a different origin.
VITE_API_BASE_URL=
