# Frontend (Vite) — only frontend-safe values. Anything in here ships to
# the browser at build time. NEVER put database URLs, JWT secrets,
# service keys, or backend-only config here.

# Base URL the frontend uses to call the backend API (no trailing slash).
# Staging / production builds (npm run build):
VITE_API_BASE_URL=https://devserver.techu.in
#
# Same-origin production (nginx serves SPA + /api): use empty.
#
# --- npm run dev (Vite on localhost:5173) ---
# Even if VITE_API_BASE_URL is set above, the app IGNORES it on localhost and
# calls /api on the SAME origin (you will see http://localhost:5173/api/...).
# That is so the Vite dev proxy can forward /api to your local backend and
# admin session cookies stay first-party. This is correct — not a bug.
#
# To force the browser to call the remote API while Vite runs locally (CORS
# / cookies may break admin auth), add to .env.local:
#   VITE_ALLOW_CROSS_ORIGIN_API_IN_DEV=true
