# Backend-only environment. Never expose these to the frontend.

NODE_ENV=production

# Required: 32+ char secret used to encrypt session cookies.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=

# ───────────────────────────────────────────────────────────────────────
# MySQL — discrete credentials (recommended for Plesk / hosting panels).
# If DATABASE_URL is not set, the app builds it as:
#   mysql://DB_USER:DB_PASSWORD@DB_HOST:DB_PORT/DB_NAME
# (Prisma still receives DATABASE_URL in memory; you do not have to paste
#  a URL string in the panel unless you prefer to.)
# ───────────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASSWORD=

# Optional: set this instead of (or in addition to) DB_* — when set, DB_* are
# not required for composing DATABASE_URL.
# DATABASE_URL=

# Bootstrap admin (created on first /api/auth/ensure-admin call).
ADMIN_EMAIL=admin@techu.in
ADMIN_PASSWORD=TechU@Admin2026

# HTTP listen options.
PORT=3001
HOST=0.0.0.0

# Optional: filesystem path to the Vite production build directory (the folder
# that contains index.html and assets/). When set, Express serves the SPA and
# static assets on the same port as the API (avoids "Cannot GET /" if all
# traffic goes to Node). Use an absolute path or a path relative to the
# process cwd (usually backend/). Example: ../frontend/dist
# FRONTEND_DIST=

# Comma-separated list of allowed cross-origin frontend origins.
# Include the staging site; keep localhost entries for local Vite dev.
CORS_ORIGINS=https://devserver.techu.in,http://localhost:5173,http://localhost:4173

# Optional: rotate the admin password from env on next ensure-admin call.
# RESET_ADMIN_PASSWORD=true
